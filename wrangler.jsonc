{
  // Static-assets deploy for the Velox House marketing site (Vite SPA) on Cloudflare
  // Workers. `npm run build` -> ./dist, then `npx wrangler deploy` uploads it. Assets-only
  // (no Worker script). SPA routing: unknown paths serve index.html.
  "name": "velox-house",
  "compatibility_date": "2024-12-30",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
